# PostgreSQL + pgvector (local Docker: v-postgres, port 5432)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=careerai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_your_password
# knowledge-service 默认复用以上 PostgreSQL；准备独立库时再覆盖这些变量。
KNOWLEDGE_POSTGRES_HOST=localhost
KNOWLEDGE_POSTGRES_PORT=5432
KNOWLEDGE_POSTGRES_DB=careerai
KNOWLEDGE_POSTGRES_USER=postgres
KNOWLEDGE_POSTGRES_PASSWORD=replace_with_your_password
KNOWLEDGE_JPA_DDL_AUTO=update

# Redis (local Docker: dev-redis7, port 6379)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=1

# RabbitMQ (local Docker: rabbitmq, ports 5672/15672)
APP_RABBITMQ_ENABLED=true
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Nacos (local Docker: nacos, ports 8848/9848/9849)
# 默认演示使用固定本地路由；需要验证服务发现时再显式开启。
NACOS_DISCOVERY_ENABLED=false
NACOS_REGISTER_ENABLED=false
NACOS_SERVER_ADDR=localhost:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=
NACOS_PASSWORD=

# Gateway route targets. Local development defaults to direct URLs for stability.
# Set to lb://careerai-app and lb://knowledge-service to verify Nacos load-balanced routing.
GATEWAY_APP_ROUTE_URI=http://localhost:8080
GATEWAY_KNOWLEDGE_ROUTE_URI=http://localhost:8081
GATEWAY_AGENT_ROUTE_URI=http://localhost:8000

# Python Agent service
AGENT_ENVIRONMENT=local
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
AGENT_LOG_LEVEL=INFO
AGENT_CAREERAI_API_BASE_URL=http://localhost:8080
AGENT_MODEL_CONFIG_BASE_URL=http://localhost:8082
AGENT_REQUEST_TIMEOUT_SECONDS=30
AGENT_CHECKPOINTER_BACKEND=memory
# AGENT_DATABASE_URL=postgresql://postgres:replace_with_your_password@localhost:5432/careerai?sslmode=disable

# Java Agent internal bridge. Use the same long random token in all three processes.
JAVA_AGENT_SERVICE_PORT=8082
AGENT_CORE_SERVICE_URL=http://localhost:8080
AGENT_INTERNAL_SERVICE_TOKEN=replace_with_a_long_random_internal_token
APP_AI_DEFAULT_AGENT_PROVIDER=dashscope

# RustFS / S3 (local Docker: v-rustfs, ports 9000/9001)
APP_STORAGE_ENDPOINT=http://localhost:9000
APP_STORAGE_ACCESS_KEY=replace_with_your_access_key
APP_STORAGE_SECRET_KEY=replace_with_your_secret_key
APP_STORAGE_BUCKET=careerai

# DashScope (LLM + embedding)
AI_BAILIAN_API_KEY=replace_with_your_api_key
AI_MODEL=qwen3.5-flash

# Frontend dev proxy. Default to gateway-service.
VITE_API_PROXY_TARGET=http://localhost:8090

# Backend service ports
GATEWAY_SERVICE_PORT=8090
SERVER_PORT=8080
KNOWLEDGE_SERVICE_PORT=8081

# Runtime provider configuration encryption
APP_AI_CONFIG_ENCRYPTION_KEY=replace_with_at_least_32_random_characters

# Auth / JWT
APP_AUTH_JWT_SECRET=replace_with_at_least_32_random_characters
APP_AUTH_ACCESS_TOKEN_TTL_MINUTES=120
APP_AUTH_ANONYMOUS_USER_ENABLED=true
APP_AUTH_ANONYMOUS_USERNAME=local-dev
APP_AUTH_ANONYMOUS_USER_ID=1
