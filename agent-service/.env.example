AGENT_ENVIRONMENT=local
AGENT_HOST=0.0.0.0
AGENT_PORT=8000
AGENT_LOG_LEVEL=INFO

# Python calls the Java core app directly. Browser traffic still enters through gateway-service.
AGENT_CAREERAI_API_BASE_URL=http://localhost:8080
# Python reads the model snapshot from the Java internal agent-service.
AGENT_MODEL_CONFIG_BASE_URL=http://localhost:8082
# Python invokes Java business Tools through the same protected bridge.
AGENT_BUSINESS_TOOL_BASE_URL=http://localhost:8082
AGENT_INTERNAL_SERVICE_TOKEN=replace_with_a_long_random_internal_token
AGENT_REQUEST_TIMEOUT_SECONDS=30

# memory is for local development and tests only. Use postgres for restart recovery.
AGENT_CHECKPOINTER_BACKEND=memory
# AGENT_DATABASE_URL=postgresql://user:password@localhost:5432/careerai?sslmode=disable
